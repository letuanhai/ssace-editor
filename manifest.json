{
  "manifest_version": 3,
  "name": "SS Ext",
  "version": "0.3",
  "description": "Extension for SAS Studio",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "SS Ext",
    "default_popup": "src/popup.html"
  },
  "commands": {
    "_execute_action": {}
  },
  "background": {
    "service_worker": "src/sw.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/SASStudio/*"],
      "js": ["src/relay.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "*://*/SASStudio/*"
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*.js",
        "src/ace/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
