{
  "manifest_version": 3,
  "name": "SS Ext",
  "version": "0.1",
  "description": "Extension for SAS Studio",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "SS Ext",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle_editor": {
      "suggested_key": {
        "default": "Alt+Period"
      },
      "description": "Toggle the Ace editor"
    },
    "browse_files": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Browse SAS Studio files"
    },
    "browse_library": {
      "suggested_key": {
        "default": "Alt+O"
      },
      "description": "Browse SAS Studio library items"
    },
    "browse_tabs": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Select SAS Studio tabs"
    }
  },
  "background": {
    "service_worker": "sw.js"
  },
  "host_permissions": [
    "*://*/SASStudio/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
