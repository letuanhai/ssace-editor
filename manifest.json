{
  "manifest_version": 3,
  "name": "SS Ext",
  "version": "1.3",
  "description": "Extension for SAS Studio",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "Activate editor"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Period"
      }
    }
  },
  "background": {
    "service_worker": "sw.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
