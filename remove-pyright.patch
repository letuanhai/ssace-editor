+// Copyright © 2024, SAS Institute Inc., Cary, NC, USA.  All Rights Reserved.
+// SPDX-License-Identifier: Apache-2.0
+import type { PyrightLanguageProvider } from "../python/PyrightLanguageProvider";
+
+// ponytail: no Python/pyright support in the browser build (would need the whole
+// pyright-internal bundle, ~7MB). Every method is a no-op; upgrade to a real
+// in-browser provider if PROC PYTHON support is ever needed in-browser.
+export class StubPythonProvider implements PyrightLanguageProvider {
+  setSasLspProvider(): void {}
+  initialize(): void {}
+  getClientCapabilities() {
+    return { hasVisualStudioExtensionsCapability: false };
+  }
+  onInitialized() {}
+  onShutdown() {}
+  addContentChange(): void {}
+  onDidOpenTextDocument() {}
+  onDidCloseTextDocument() {}
+  onDidChangeConfiguration() {}
+  onDidChangeWatchedFiles() {}
+  onHover() {
+    return null;
+  }
+  async onCompletion() {
+    return { isIncomplete: false, items: [] };
+  }
+  onCompletionResolve(completionItem: unknown) {
+    return completionItem;
+  }
+  onSignatureHelp() {
+    return null;
+  }
+  onDefinition() {
+    return null;
+  }
+  onDeclaration() {
+    return null;
+  }
+  onTypeDefinition() {
+    return null;
+  }
+  onReferences() {
+    return null;
+  }
+  onDocumentSymbol() {
+    return [];
+  }
+  onWorkspaceSymbol() {
+    return [];
+  }
+  onDocumentHighlight() {
+    return null;
+  }
+  onPrepareRenameRequest() {
+    return null;
+  }
+  onRenameRequest() {
+    return null;
+  }
+  onCallHierarchyPrepare() {
+    return null;
+  }
+  onCallHierarchyIncomingCalls() {
+    return [];
+  }
+  onCallHierarchyOutgoingCalls() {
+    return [];
+  }
+  onExecuteCommand() {
+    return null;
+  }
+  executeCodeAction() {
+    return null;
+  }
+}
