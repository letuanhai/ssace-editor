 // Copyright © 2024, SAS Institute Inc., Cary, NC, USA.  All Rights Reserved.
 // SPDX-License-Identifier: Apache-2.0
-import type { PyrightLanguageProviderBrowser } from "./browser/PyrightLanguageProviderBrowser";
-import type { PyrightLanguageProviderNode } from "./node/PyrightLanguageProviderNode";
+// ponytail: structural interface instead of the pyright-importing union type, so
+// browser/StubPythonProvider.ts can implement it without pulling pyright into the
+// browser bundle. Loose (any) types are fine here; server.ts only needs shape.
+import type { CompletionList } from "vscode-languageserver";
 
-export type PyrightLanguageProvider =
-  | PyrightLanguageProviderNode
-  | PyrightLanguageProviderBrowser;
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+export interface PyrightLanguageProvider {
+  setSasLspProvider(getLanguageService: any): void;
+  initialize(params: any, a: any[], b: any[]): void;
+  getClientCapabilities(): any;
+  onInitialized(): any;
+  onShutdown(token: any): any;
+  addContentChange(document: any): void;
+  onDidOpenTextDocument(params: any): any;
+  onDidCloseTextDocument(params: any): any;
+  onDidChangeConfiguration(params: any): any;
+  onDidChangeWatchedFiles(params: any): any;
+  onHover(params: any, token: any): any;
+  onCompletion(
+    params: any,
+    token: any,
+  ): Promise<CompletionList | null | undefined>;
+  onCompletionResolve(completionItem: any, token: any): any;
+  onSignatureHelp(params: any, token: any): any;
+  onDefinition(params: any, token: any): any;
+  onDeclaration(params: any, token: any): any;
+  onTypeDefinition(params: any, token: any): any;
+  onReferences(
+    params: any,
+    token: any,
+    workDoneReporter?: any,
+    resultReporter?: any,
+    createDocumentRange?: any,
+    convertToLocation?: any,
+  ): any;
+  onDocumentSymbol(params: any, token: any): any;
+  onWorkspaceSymbol(params: any, token: any, resultProgress?: any): any;
+  onDocumentHighlight(params: any, token: any): any;
+  onPrepareRenameRequest(params: any, token: any): any;
+  onRenameRequest(params: any, token: any): any;
+  onCallHierarchyPrepare(params: any, token: any): any;
+  onCallHierarchyIncomingCalls(params: any, token: any): any;
+  onCallHierarchyOutgoingCalls(params: any, token: any): any;
+  onExecuteCommand(params: any, token: any, reporter?: any): any;
+  executeCodeAction(params: any, token: any): any;
+}
